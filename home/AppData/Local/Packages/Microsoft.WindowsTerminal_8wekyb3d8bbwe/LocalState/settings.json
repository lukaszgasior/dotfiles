{
  "$help": "https://aka.ms/terminal-documentation",
  "$schema": "https://aka.ms/terminal-profiles-schema",
  "actions": [
    {
      "command": {
        "action": "copy",
        "singleLine": false
      },
      "id": "User.copy"
    },
    {
      "command": "find",
      "id": "User.find"
    },
    {
      "command": "paste",
      "id": "User.paste"
    }
  ],
  "copyFormatting": "none",
  "copyOnSelect": false,
  "defaultProfile": "{574e775e-4f2a-5b96-ac1e-a2962a402336}",
  "keybindings": [
    {
      "id": "User.copy",
      "keys": "ctrl+c"
    },
    {
      "id": "Terminal.DuplicatePaneDown",
      "keys": "alt+shift+minus"
    },
    {
      "id": "Terminal.TogglePaneZoom",
      "keys": "ctrl+shift+z"
    },
    {
      "id": "User.paste",
      "keys": "ctrl+v"
    },
    {
      "id": "User.find",
      "keys": "ctrl+shift+f"
    },
    {
      "id": "Terminal.ClosePane",
      "keys": "ctrl+shift+w"
    },
    {
      "id": "Terminal.ToggleFocusMode",
      "keys": "ctrl+shift+enter"
    },
    {
      "id": "Terminal.DuplicatePaneRight",
      "keys": "alt+shift+plus"
    },
    {
      "id": "Terminal.MoveFocusLeft",
      "keys": "ctrl+alt+left"
    },
    {
      "id": "Terminal.MoveFocusRight",
      "keys": "ctrl+alt+right"
    },
    {
      "id": "Terminal.MoveFocusUp",
      "keys": "ctrl+alt+up"
    },
    {
      "id": "Terminal.MoveFocusDown",
      "keys": "ctrl+alt+down"
    }
  ],
  "newTabMenu": [
    {
      "type": "remainingProfiles"
    }
  ],
  "profiles": {
    "defaults": {
      "bellStyle": "window",
      "closeOnExit": "always",
      "colorScheme": "Gruvbox",
      "cursorShape": "filledBox",
      "font": {
        "face": "UbuntuMono Nerd Font",
        "size": 15,
        "weight": "normal"
      },
      "historySize": 10000,
      "opacity": 85,
      "padding": "8, 8, 8, 8",
      "scrollbarState": "hidden",
      "suppressApplicationTitle": false,
      "unfocusedAppearance": {
        "opacity": 60
      },
      "useAcrylic": true
    },
